---
// Footer / seção de contato — estático. Marquee CSS puro.
import Icon from '../ui/Icon.astro';
---

<div class="w-full overflow-hidden">
  <footer id="contato" class="w-full h-screen flex flex-col justify-between sm:justify-normal">
    <div class="w-full h-full flex flex-col">

      <div class="w-full flex flex-row justify-between items-center px-[4vw] pt-6 sm:pt-25 gap-2 sm:gap-0">
        <h2 class="font-mono text-xl sm:text-2xl font-bold">/* CONTATO */</h2>
        <a
          href="/doc/joaovitorcurriculo.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="w-35 h-12.5 rounded-[30px] bg-linear-to-br from-background-start to-background-end hover:translate-y-[-5%] transition-transform duration-500 ease-out flex items-center justify-center text-primary text-base hover:font-medium"
        >CURRÍCULO</a>
      </div>

      <div class="flex-1 overflow-hidden w-full flex items-center">
        <div class="h-full w-max flex items-center justify-center" aria-hidden="true">
          <div class="animate-[marquee-anim_20s_infinite_linear] font-mono font-bold pl-5 sm:pl-25 text-[16vw] sm:text-[12vw] whitespace-nowrap">JOÃO VITOR GOMES DE FARIA</div>
          <div class="animate-[marquee-anim_20s_infinite_linear] font-mono font-bold pl-5 sm:pl-25 text-[16vw] sm:text-[12vw] whitespace-nowrap">JOÃO VITOR GOMES DE FARIA</div>
          <div class="animate-[marquee-anim_20s_infinite_linear] font-mono font-bold pl-5 sm:pl-25 text-[16vw] sm:text-[12vw] whitespace-nowrap">JOÃO VITOR GOMES DE FARIA</div>
        </div>
      </div>

      <div class="px-[3.4vw] mb-4 sm:mb-5 flex gap-4 items-start sm:items-center">
        <a href="https://www.linkedin.com/in/joaovitor-faria/" target="_blank" rel="noopener noreferrer" aria-label="Acesse meu perfil no LinkedIn" class="w-7 sm:w-8 h-7 sm:h-8 flex items-center justify-center text-primary hover:text-[#8a8a8a] transition-colors duration-300">
          <Icon name="linkedin" class="w-6.5 h-6.5 sm:w-7.5 sm:h-7.5" />
        </a>
        <a href="https://github.com/joaoviitordev" target="_blank" rel="noopener noreferrer" aria-label="Acesse meu perfil no GitHub" class="w-7 sm:w-8 h-7 sm:h-8 flex items-center justify-center text-primary hover:text-[#8a8a8a] transition-colors duration-300">
          <Icon name="github" class="w-6.5 h-6.5 sm:w-7.5 sm:h-7.5" />
        </a>
      </div>

      <div class="w-full flex flex-col sm:flex-row justify-between items-start sm:items-center px-[3.6vw] pb-6 sm:pb-8 gap-3 sm:gap-0 sm:transform-none -translate-y-4 sm:translate-y-0">
        <p class="font-mono font-bold text-lg sm:text-[1.4vw] lg:text-[1.2vw] m-0">E-mail: joaovitorgomesdefaria@gmail.com</p>
        <p class="font-mono font-bold text-lg sm:text-[1.4vw] lg:text-[1.2vw] m-0">/* KEEP PUSHING THE LIMITS */</p>
      </div>

    </div>
  </footer>
</div>
