---
// Tecnologias — estático. Grid bento com tamanhos variáveis.
const techs = [
  { name: 'HTML5', icon: '/assets/icons/html5.svg', size: 'wide' },
  { name: 'React', icon: '/assets/icons/react.svg', size: 'wide' },
  { name: 'CSS3', icon: '/assets/icons/css3.svg', size: 'normal' },
  { name: 'JavaScript (ES6+)', icon: '/assets/icons/js.svg', size: 'wide' },
  { name: 'GSAP', icon: '/assets/icons/gsap2.svg', size: 'normal' },
  { name: 'Figma', icon: '/assets/icons/figma.svg', size: 'wide' },
  { name: 'Node.js', icon: '/assets/icons/nodejs2.svg', size: 'wide' },
  { name: 'Git', icon: '/assets/icons/git.svg', size: 'normal' },
  { name: 'GitHub', icon: '/assets/icons/github.svg', size: 'wide' },
  { name: 'Next.js', icon: '/assets/icons/nextjs.svg', size: 'wide' },
  { name: 'TypeScript', icon: '/assets/icons/typescript.svg', size: 'tall' },
  { name: 'PostgreSQL', icon: '/assets/icons/postgresql.svg', size: 'normal' },
];

function classesFor(size: string) {
  let colSpan = 'col-span-1';
  let rowSpan = 'row-span-1';
  let iconSize = 'w-15 h-15 sm:w-17.5 sm:h-17.5 lg:w-20 lg:h-20';
  let textSize = 'text-base sm:text-lg lg:text-xl';

  if (size === 'large') {
    colSpan = 'col-span-2';
    rowSpan = 'row-span-1 sm:row-span-2';
    iconSize = 'w-17.5 h-17.5 sm:w-25 sm:h-25 lg:w-35 lg:h-35';
    textSize = 'text-lg sm:text-[22px] lg:text-[26px]';
  } else if (size === 'tall') {
    rowSpan = 'row-span-2';
    iconSize = 'w-17.5 h-17.5 sm:w-20 sm:h-20 lg:w-25 lg:h-25';
    textSize = 'text-lg sm:text-xl lg:text-[22px]';
  } else if (size === 'wide') {
    colSpan = 'col-span-2';
  }
  return { colSpan, rowSpan, iconSize, textSize };
}
---

<section id="tecnologias" class="w-full min-h-auto sm:min-h-screen flex flex-col items-center px-[4vw] py-10 sm:py-25">
  <h2 class="font-mono text-primary text-xl sm:text-2xl font-bold w-full text-left mb-8 sm:mb-12">
    /* TECNOLOGIAS */
  </h2>

  <div class="w-full max-w-275 grid grid-cols-2 lg:grid-cols-4 grid-flow-dense gap-4 sm:gap-6 auto-rows-37.5 sm:auto-rows-50 lg:auto-rows-60">
    {techs.map((tech) => {
      const { colSpan, rowSpan, iconSize, textSize } = classesFor(tech.size);
      return (
        <div
          class={`flex flex-col items-center justify-center gap-4 sm:gap-6 p-4 sm:p-6 rounded-2xl sm:rounded-3xl bg-white/40 backdrop-blur-md border border-white/40 shadow-[0_10px_30px_rgba(0,0,0,0.05)] transition-all duration-300 ease-in hover:-translate-y-2 hover:bg-white/60 hover:shadow-[0_15px_35px_rgba(0,0,0,0.1)] ${colSpan} ${rowSpan}`}
        >
          <img
            src={tech.icon}
            alt={`Ícone da tecnologia ${tech.name}`}
            loading="lazy"
            class={`${iconSize} object-contain drop-shadow-md`}
          />
          <span class={`font-sans font-semibold text-primary text-center ${textSize}`}>
            {tech.name}
          </span>
        </div>
      );
    })}
  </div>
</section>
