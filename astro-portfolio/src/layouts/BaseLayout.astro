---
// Layout base — equivale ao RootLayout (layout.tsx) do Next.
// Fontes self-hosted via Fontsource (substituem next/font/google).
import '@fontsource/poppins/300.css';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';
import '@fontsource/space-mono/400.css';
import '@fontsource/space-mono/700.css';

import '../styles/global.css';
import SEO from '../components/seo/SEO.astro';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const { title, description, path } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon/myfavicon.svg" />

    <SEO title={title} description={description} path={path} />

    <!-- FontAwesome kit (mantido via CDN na Fase 1/2; candidato a inline na Fase 5) -->
    <script src="https://kit.fontawesome.com/48fc6e8f37.js" crossorigin="anonymous" is:inline></script>
  </head>
  <body>
    <slot />
  </body>
</html>
